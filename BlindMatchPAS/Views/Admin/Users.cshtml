@using Microsoft.AspNetCore.Identity
@model IEnumerable<BlindMatchPAS.Models.ApplicationUser>
@{
    ViewData["Title"] = "User Management";
    var userRoles = ViewBag.UserRoles as Dictionary<string, IList<string>> ?? new();
    var currentRole = ViewBag.CurrentRole as string ?? "";
    var currentSearch = ViewBag.CurrentSearch as string ?? "";
    var roleOptions = new[] { "Student", "Supervisor", "ModuleLeader", "SystemAdmin" };
}

<div x-data="{ showModal: false, deleteId: '', deleteName: '' }">

  <div class="flex items-center justify-between mb-6">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-xl bg-teal-50 flex items-center justify-center">
        <i class="fas fa-users text-teal-600"></i>
      </div>
      <div>
        <h1 class="text-2xl font-bold text-slate-900 leading-none">User Management</h1>
        <p class="text-sm text-slate-500 mt-0.5">@Model.Count() registered users</p>
      </div>
    </div>
    <a asp-action="CreateUser" class="btn bg-teal-500 hover:bg-teal-600 text-white border-none shadow-sm gap-2">
      <i class="fas fa-user-plus"></i>Create User
    </a>
  </div>

  <form method="get" asp-action="Users" class="flex flex-wrap gap-3 mb-5">
    <div class="relative flex-1 min-w-[200px]">
      <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm"></i>
      <input type="text" name="search" value="@currentSearch" placeholder="Search name or email…"
             class="input input-bordered w-full pl-9 text-sm text-slate-800 bg-white focus:border-teal-400 focus:outline-none" />
    </div>
    <select name="role" class="select select-bordered text-sm text-slate-700 bg-white focus:border-teal-400 focus:outline-none">
      <option value="">All Roles</option>
      @foreach (var r in roleOptions)
      {
        <option value="@r" selected="@(currentRole == r ? "selected" : null)">@r</option>
      }
    </select>
    <button type="submit" class="btn bg-teal-500 hover:bg-teal-600 text-white border-none gap-2">
      <i class="fas fa-filter"></i>Filter
    </button>
    @if (!string.IsNullOrEmpty(currentRole) || !string.IsNullOrEmpty(currentSearch))
    {
      <a asp-action="Users" class="btn btn-ghost text-slate-500 gap-2">
        <i class="fas fa-times"></i>Clear
      </a>
    }
  </form>

  <div class="overflow-x-auto rounded-2xl border border-slate-200 bg-white shadow-sm">
    <table class="table table-zebra bg-white">
      <thead>
        <tr>
          <th class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Full Name</th>
          <th class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Email</th>
          <th class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Role(s)</th>
          <th class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Department</th>
          <th class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Institution ID</th>
          <th class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Joined</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        @foreach (var user in Model)
        {
          var roles2 = userRoles.GetValueOrDefault(user.Id, new List<string>());
          var safeName = user.FullName?.Replace("'", "\\'") ?? "";
          <tr>
            <td>
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-full bg-teal-500 flex items-center justify-center text-white text-xs font-bold">
                  @(user.FullName?.Substring(0, 1).ToUpper() ?? "?")
                </div>
                <span class="font-semibold text-slate-900">@user.FullName</span>
              </div>
            </td>
            <td class="text-slate-600 text-sm">@user.Email</td>
            <td>
              <div class="flex flex-wrap gap-1">
                @foreach (var role in roles2)
                {
                  var pillClass = role switch {
                    "Student"      => "role-badge-student",
                    "Supervisor"   => "role-badge-supervisor",
                    "ModuleLeader" => "role-badge-leader",
                    "SystemAdmin"  => "role-badge-admin",
                    _              => "role-badge-default"
                  };
                  <span class="badge @pillClass">@role</span>
                }
              </div>
            </td>
            <td class="text-slate-600 text-sm">@(user.Department ?? "—")</td>
            <td class="text-slate-600 text-sm font-mono text-xs">@(user.StudentId ?? user.FacultyId ?? "—")</td>
            <td class="text-slate-500 text-sm">@user.CreatedAt.ToString("dd MMM yyyy")</td>
            <td>
              <button type="button"
                      @@click="deleteId = '@user.Id'; deleteName = '@safeName'; showModal = true"
                      class="btn btn-sm btn-ghost text-red-500 hover:bg-red-50" title="Delete user">
                <i class="fas fa-trash-alt"></i>
              </button>
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>

  <div x-show="showModal" x-cloak
       class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm"
       @@click.self="showModal = false">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm mx-4 p-6">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-12 h-12 rounded-full bg-red-100 flex items-center justify-center flex-shrink-0">
          <i class="fas fa-exclamation-triangle text-red-500 text-xl"></i>
        </div>
        <div>
          <h3 class="font-bold text-slate-900 text-lg">Delete User</h3>
          <p class="text-slate-500 text-sm">This action cannot be undone.</p>
        </div>
      </div>
      <p class="text-slate-700 mb-6">Delete <strong x-text="deleteName"></strong>? All their proposals and matches will also be removed.</p>
      <div class="flex gap-3 justify-end">
        <button type="button" @@click="showModal = false"
                class="btn btn-ghost text-slate-600">Cancel</button>
        <form asp-action="DeleteUser" method="post">
          @Html.AntiForgeryToken()
          <input type="hidden" name="id" x-bind:value="deleteId" />
          <button type="submit" class="btn bg-red-500 hover:bg-red-600 text-white border-none gap-2">
            <i class="fas fa-trash-alt"></i>Delete
          </button>
        </form>
      </div>
    </div>
  </div>

</div>


