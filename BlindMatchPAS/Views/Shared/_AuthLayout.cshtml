<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="BlindMatch PAS — Fair, merit-based supervisor matching for academic projects." />
    <title>@ViewData["Title"] – BlindMatch PAS</title>
    <link href="https://cdn.jsdelivr.net/npm/daisyui@4.12.10/dist/full.min.css" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = { corePlugins: { preflight: false }, theme: { extend: { fontFamily: { sans: ["'Inter'", 'system-ui', '-apple-system', 'BlinkMacSystemFont', "'Segoe UI'", 'sans-serif'] }, colors: { primary: '#0F172A', accent: '#0D9488' } } } }
    </script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
          crossorigin="anonymous" referrerpolicy="no-referrer" />
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
</head>
<body class="bm-auth-body">
    <a class="sr-only focus:not-sr-only absolute top-2 left-2 z-50 bg-[#00A8A8] text-white px-3 py-1 rounded" href="#main-content">Skip to main content</a>

    <div class="navbar bg-white border-b-2 border-teal-500 shadow-sm px-6" role="banner">
      <div class="navbar-start">
        <a asp-controller="Home" asp-action="Index" class="flex items-center gap-2 text-slate-900 font-bold text-lg hover:text-teal-600 transition-colors">
          <i class="fas fa-eye-slash text-teal-500"></i>
          <span>BlindMatch PAS</span>
        </a>
      </div>
      <div class="navbar-end">
        <partial name="_LoginPartial" />
      </div>
    </div>

    <main id="main-content" role="main">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
