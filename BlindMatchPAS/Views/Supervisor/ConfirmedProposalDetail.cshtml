@model BlindMatchPAS.Models.ProjectProposal
@{
    ViewData["Title"] = "Confirmed Proposal";
    var studentName  = ViewBag.StudentName  as string ?? "Unknown";
    var studentEmail = ViewBag.StudentEmail as string ?? string.Empty;
    var studentIdNo  = ViewBag.StudentIdNo  as string;
    var note         = ViewBag.Note         as string;
    var confirmedAt  = ViewBag.ConfirmedAt  as DateTime?;
}

<div class="max-w-3xl mx-auto">

  <a asp-action="Dashboard" class="inline-flex items-center gap-2 text-sm text-slate-500 hover:text-teal-600 mb-6 transition-colors">
    <i class="fas fa-arrow-left"></i>Back to Dashboard
  </a>

  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden mb-6">
    <div class="bg-gradient-to-r from-slate-900 to-teal-900 px-6 py-5" style="color:#ffffff">
      <div class="flex flex-wrap items-start justify-between gap-3">
        <div>
          <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-teal-400/20 text-teal-200 border border-teal-400/30 mb-3">
            <i class="fas fa-flask mr-1.5"></i>@Model.ResearchArea?.Name
          </span>
          <h1 class="text-xl font-bold break-all" style="color:#ffffff">@Model.Title</h1>
        </div>
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-emerald-400/20 text-emerald-200 border border-emerald-400/30 text-xs font-semibold whitespace-nowrap">
          <i class="fas fa-check-circle"></i>Matched
        </span>
      </div>
    </div>

    <div class="p-6 space-y-6">

      @* Identity reveal panel *@
      <div class="bg-emerald-50 border border-emerald-200 rounded-xl p-4">
        <div class="flex items-center gap-2 mb-3">
          <i class="fas fa-user-check text-emerald-600"></i>
          <p class="text-sm font-semibold text-emerald-800">Identity Revealed</p>
          @if (confirmedAt.HasValue)
          {
            <span class="ml-auto text-xs text-emerald-600">Confirmed @confirmedAt.Value.ToString("dd MMM yyyy")</span>
          }
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 text-sm">
          <div>
            <p class="text-xs text-slate-500 mb-0.5">Name</p>
            <p class="font-semibold text-slate-800">@studentName</p>
          </div>
          <div>
            <p class="text-xs text-slate-500 mb-0.5">Email</p>
            <a href="mailto:@studentEmail" class="font-medium text-teal-600 hover:underline break-all">@studentEmail</a>
          </div>
          <div>
            <p class="text-xs text-slate-500 mb-0.5">Student ID</p>
            <p class="font-mono text-slate-700">@(studentIdNo ?? "—")</p>
          </div>
        </div>
      </div>

      @* Abstract *@
      <div>
        <h2 class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-2">Abstract</h2>
        <p class="text-sm text-slate-700 leading-relaxed break-all">@Model.Abstract</p>
      </div>

      @* Tech stack *@
      <div>
        <h2 class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-2">Technical Stack</h2>
        <div class="flex flex-wrap gap-2">
          @foreach (var tech in Model.TechnicalStack.Split(',', StringSplitOptions.RemoveEmptyEntries))
          {
            <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-slate-100 text-slate-700 text-xs font-medium border border-slate-200">
              <i class="fas fa-code text-teal-500 text-[10px]"></i>@tech.Trim()
            </span>
          }
        </div>
      </div>

      @* Supervisor note *@
      @if (!string.IsNullOrWhiteSpace(note))
      {
        <div>
          <h2 class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-2">Your Note to Student</h2>
          <div class="bg-slate-50 border border-slate-200 rounded-xl p-4 text-sm text-slate-700 italic">@note</div>
        </div>
      }

    </div>
  </div>

</div>
