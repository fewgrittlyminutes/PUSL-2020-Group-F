@model BlindMatchPAS.ViewModels.Supervisor.AnonymousProposalViewModel
@{
    ViewData["Title"] = "Proposal Detail";
}

<div class="max-w-3xl mx-auto">

  @* Back link *@
  <a asp-action="Browse" class="inline-flex items-center gap-2 text-sm text-slate-500 hover:text-teal-600 mb-6 transition-colors">
    <i class="fas fa-arrow-left"></i>Back to Browse
  </a>

  @* Header card *@
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden mb-6">
    <div class="bg-gradient-to-r from-slate-900 to-teal-900 px-6 py-5" style="color:#ffffff">
      <div class="flex flex-wrap items-start justify-between gap-3">
        <div>
          <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-teal-400/20 text-teal-200 border border-teal-400/30 mb-3">
            <i class="fas fa-flask mr-1.5"></i>@Model.ResearchAreaName
          </span>
          <h1 class="text-xl font-bold break-all" style="color:#ffffff">@Model.Title</h1>
        </div>
        <span class="text-xs text-slate-400 whitespace-nowrap">@Model.SubmittedAt.ToString("dd MMM yyyy")</span>
      </div>
    </div>

    <div class="p-6 space-y-6">

      @* Anonymous notice *@
      <div class="flex items-start gap-3 bg-blue-50 border border-blue-200 rounded-xl p-4">
        <i class="fas fa-eye-slash text-blue-500 mt-0.5"></i>
        <div>
          <p class="text-sm font-semibold text-blue-800">Anonymous mode active</p>
          <p class="text-xs text-blue-600 mt-0.5">Student identity hidden. Revealed only after you confirm match.</p>
        </div>
      </div>

      @* Abstract *@
      <div>
        <h2 class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-2">Abstract</h2>
        <p class="text-sm text-slate-700 leading-relaxed break-all">@Model.Abstract</p>
      </div>

      @* Tech stack *@
      <div>
        <h2 class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-2">Technical Stack</h2>
        <div class="flex flex-wrap gap-2">
          @foreach (var tech in Model.TechnicalStack.Split(',', StringSplitOptions.RemoveEmptyEntries))
          {
            <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-slate-100 text-slate-700 text-xs font-medium border border-slate-200 break-all">
              <i class="fas fa-code text-teal-500 text-[10px]"></i>@tech.Trim()
            </span>
          }
        </div>
      </div>

    </div>
  </div>

  @* Action card *@
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6">
    <h2 class="text-sm font-semibold text-slate-700 mb-1">Interested in supervising this project?</h2>
    <p class="text-xs text-slate-500 mb-4">Expressing interest moves proposal to "Under Review". You can confirm the match from your dashboard.</p>
    <div class="flex flex-wrap gap-3">
      <form asp-action="ExpressInterest" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="proposalId" value="@Model.ProposalId" />
        <button type="submit" class="btn bg-teal-500 hover:bg-teal-600 text-white border-none shadow-sm gap-2">
          <i class="fas fa-hand-point-right"></i>Express Interest
        </button>
      </form>
      <a asp-action="Browse" class="btn btn-outline border-slate-300 text-slate-600 hover:bg-slate-100 gap-2">
        <i class="fas fa-arrow-left"></i>Back
      </a>
    </div>
  </div>

</div>
