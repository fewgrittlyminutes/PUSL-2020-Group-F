@{
    ViewData["Title"] = "Supervisor Dashboard";
    var available = ViewBag.AvailableProposals as List<AnonymousProposalViewModel> ?? new();
    var interested = ViewBag.InterestedProposals as List<AnonymousProposalViewModel> ?? new();
    var confirmed = ViewBag.ConfirmedMatches as List<RevealedMatchViewModel> ?? new();
}

<div class="flex items-center gap-3 mb-8">
  <div class="w-10 h-10 rounded-xl bg-teal-50 flex items-center justify-center">
    <i class="fas fa-tachometer-alt text-teal-600"></i>
  </div>
  <div>
    <h1 class="text-2xl font-bold text-slate-900 leading-none">Supervisor Dashboard</h1>
    <p class="text-sm text-slate-500 mt-0.5">Your proposals and confirmed matches</p>
  </div>
</div>

<div class="grid grid-cols-1 sm:grid-cols-3 gap-5 mb-10">
  <div class="bg-white rounded-2xl border border-slate-200 p-6 flex items-center gap-4 hover:shadow-md transition-shadow">
    <div class="w-14 h-14 flex-shrink-0 rounded-2xl bg-teal-50 flex items-center justify-center">
      <i class="fas fa-inbox text-teal-500 text-2xl"></i>
    </div>
    <div>
      <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-1">Available</p>
      <p class="text-4xl font-extrabold text-slate-900">@available.Count</p>
    </div>
  </div>
  <div class="bg-white rounded-2xl border border-slate-200 p-6 flex items-center gap-4 hover:shadow-md transition-shadow">
    <div class="w-14 h-14 flex-shrink-0 rounded-2xl bg-amber-50 flex items-center justify-center">
      <i class="fas fa-hourglass-half text-amber-500 text-2xl"></i>
    </div>
    <div>
      <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-1">Under Review</p>
      <p class="text-4xl font-extrabold text-slate-900">@interested.Count</p>
    </div>
  </div>
  <div class="bg-white rounded-2xl border border-slate-200 p-6 flex items-center gap-4 hover:shadow-md transition-shadow">
    <div class="w-14 h-14 flex-shrink-0 rounded-2xl bg-emerald-50 flex items-center justify-center">
      <i class="fas fa-handshake text-emerald-500 text-2xl"></i>
    </div>
    <div>
      <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-1">Confirmed</p>
      <p class="text-4xl font-extrabold text-slate-900">@confirmed.Count</p>
    </div>
  </div>
</div>

@if (interested.Any())
{
  <div class="flex items-center gap-2 mb-4">
    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-amber-50 text-amber-700 text-xs font-semibold border border-amber-200">
      <i class="fas fa-hourglass-half"></i>Proposals Under Review
    </span>
  </div>
  @foreach (var p in interested)
  {
    <div class="bg-white rounded-2xl border border-slate-200 border-l-4 border-l-amber-400 p-5 mb-4 hover:shadow-md transition-shadow overflow-hidden">
      <div class="flex items-start justify-between gap-2 mb-2 min-w-0">
        <h3 class="font-semibold text-slate-900 truncate" title="@p.Title">@p.Title</h3>
        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-teal-50 text-teal-700 border border-teal-200 whitespace-nowrap flex-shrink-0">@p.ResearchAreaName</span>
      </div>
      <p class="text-sm text-slate-600 mb-3 break-words line-clamp-3">@p.Abstract.Substring(0, Math.Min(220, p.Abstract.Length))@(p.Abstract.Length > 220 ? "…" : "")</p>
      <p class="text-xs text-slate-500 mb-4 truncate" title="@p.TechnicalStack"><i class="fas fa-code text-teal-400 mr-1"></i>@p.TechnicalStack</p>
      <div class="flex gap-2 flex-wrap">
        <a asp-action="ConfirmMatch" asp-route-proposalId="@p.ProposalId"
           class="btn btn-sm bg-teal-500 hover:bg-teal-600 text-white border-none shadow-sm">
          <i class="fas fa-check-circle"></i>Confirm Match &amp; Reveal Identity
        </a>
        <form asp-action="WithdrawInterest" method="post" class="inline">
          <input type="hidden" name="proposalId" value="@p.ProposalId" />
          @Html.AntiForgeryToken()
          <button type="submit" class="btn btn-sm btn-outline border-slate-300 text-slate-600 hover:bg-slate-100"
                  onclick="return confirm('Withdraw interest? The proposal will return to the pool.')">
            <i class="fas fa-times-circle"></i>Withdraw Interest
          </button>
        </form>
      </div>
    </div>
  }
}

@if (confirmed.Any())
{
  <div class="flex items-center gap-2 mb-4 mt-8">
    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-emerald-50 text-emerald-700 text-xs font-semibold border border-emerald-200">
      <i class="fas fa-handshake"></i>Confirmed Matches
    </span>
  </div>
  <div class="overflow-x-auto mb-6 rounded-2xl border border-slate-200 bg-white shadow-sm">
    <table class="table table-zebra bg-white">
      <thead>
        <tr>
          <th class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Project</th>
          <th class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Student</th>
          <th class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Contact</th>
          <th class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Student ID</th>
          <th class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Confirmed</th>
          <th class="text-xs font-semibold text-slate-500 uppercase tracking-wide"></th>
        </tr>
      </thead>
      <tbody>
        @foreach (var m in confirmed)
        {
          <tr>
            <td class="font-semibold text-slate-900">@m.ProposalTitle</td>
            <td class="font-medium text-slate-800">@m.StudentName</td>
            <td><a href="mailto:@m.StudentEmail" class="text-teal-600 hover:underline">@m.StudentEmail</a></td>
            <td class="font-mono text-xs text-slate-600">@(m.StudentId ?? "\u2014")</td>
            <td>@m.ConfirmedAt.ToString("dd MMM yyyy")</td>
            <td>
              <a asp-action="ConfirmedProposalDetail" asp-route-proposalId="@m.ProposalId"
                 class="btn btn-xs btn-outline border-teal-400 text-teal-700 hover:bg-teal-50 gap-1">
                <i class="fas fa-eye"></i>View
              </a>
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>
}

<div class="flex gap-3 mt-8">
  <a asp-action="Browse" class="btn bg-teal-500 hover:bg-teal-600 text-white border-none shadow-sm">
    <i class="fas fa-search"></i>Browse All Proposals
  </a>
  <a asp-action="ManageExpertise" class="btn btn-outline border-slate-300 text-slate-700 hover:bg-slate-100">
    <i class="fas fa-tags"></i>Manage Expertise
  </a>
</div>

