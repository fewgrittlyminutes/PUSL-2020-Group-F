@model IEnumerable<ProposalStatusViewModel>
@{
    ViewData["Title"] = "My Proposals";
}

<div class="flex items-center justify-between mb-8">
  <div class="flex items-center gap-3">
    <div class="w-10 h-10 rounded-xl bg-teal-50 flex items-center justify-center">
      <i class="fas fa-folder-open text-teal-600"></i>
    </div>
    <div>
      <h1 class="text-2xl font-bold text-slate-900 leading-none">My Proposals</h1>
      <p class="text-sm text-slate-500 mt-0.5">Track your project status</p>
    </div>
  </div>
  <a asp-action="Submit" class="btn bg-teal-500 hover:bg-teal-600 text-white border-none shadow-sm gap-2">
    <i class="fas fa-plus-circle"></i>New Proposal
  </a>
</div>

@if (!Model.Any())
{
  <div class="alert alert-info shadow-sm">
    <i class="fas fa-info-circle"></i>
    <span>You have no proposals yet. <a asp-action="Submit" class="font-semibold underline">Submit your first proposal!</a></span>
  </div>
}
else
{
  @foreach (var proposal in Model)
  {
    var accentClass = proposal.Status switch
    {
      ProposalStatus.Matched      => "border-l-emerald-500",
      ProposalStatus.UnderReview  => "border-l-amber-500",
      ProposalStatus.Withdrawn    => "border-l-slate-400",
      _                           => "border-l-teal-400"
    };
    var badgePill = proposal.Status switch
    {
      ProposalStatus.Matched      => "bg-emerald-50 text-emerald-700 border border-emerald-200",
      ProposalStatus.UnderReview  => "bg-amber-50 text-amber-700 border border-amber-200",
      ProposalStatus.Withdrawn    => "bg-slate-100 text-slate-500 border border-slate-200",
      ProposalStatus.Pending      => "bg-teal-50 text-teal-700 border border-teal-200",
      _                           => "bg-slate-100 text-slate-600 border border-slate-200"
    };

    <div class="bg-white rounded-2xl border border-slate-200 border-l-4 @accentClass p-5 mb-4 hover:shadow-md transition-shadow">
      <div class="flex flex-wrap items-start justify-between gap-2 mb-2">
        <h2 class="font-semibold text-slate-900 text-base break-all">@proposal.Title</h2>
        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold @badgePill">@proposal.Status</span>
      </div>
      <p class="text-sm text-slate-500 mb-3">
        <i class="fas fa-flask text-teal-400 mr-1"></i>@proposal.ResearchAreaName
        <span class="text-slate-300 mx-2">|</span>
        <i class="fas fa-clock text-slate-400 mr-1"></i>@proposal.SubmittedAt.ToString("dd MMM yyyy")
      </p>
      <p class="text-sm text-slate-700 mb-3 break-all">@proposal.Abstract.Substring(0, Math.Min(200, proposal.Abstract.Length))@(proposal.Abstract.Length > 200 ? "…" : "")</p>
      <p class="text-xs text-slate-500 mb-2 break-all"><i class="fas fa-code text-teal-400 mr-1"></i><strong>Stack:</strong> @proposal.TechnicalStack</p>

        @if (proposal.IsRevealed && proposal.SupervisorName != null)
        {
          <div class="bg-emerald-50 border border-emerald-200 rounded-xl mt-4 p-4">
            <h3 class="font-bold text-emerald-800 text-sm flex items-center gap-1.5 mb-2"><i class="fas fa-handshake"></i>Matched! Supervisor Details Revealed</h3>
              <p class="text-sm mt-1">
                <strong>@proposal.SupervisorName</strong> –
                <a href="mailto:@proposal.SupervisorEmail" class="underline text-teal-700">@proposal.SupervisorEmail</a>
                @if (proposal.SupervisorDepartment != null)
                {
                  <span class="text-emerald-700"> | @proposal.SupervisorDepartment</span>
                }
              </p>
              @if (proposal.SupervisorNote != null)
              {
                <p class="text-xs text-emerald-700 mt-1"><i class="fas fa-comment mr-1"></i>@proposal.SupervisorNote</p>
              }
          </div>
        }

        @if (proposal.Status != ProposalStatus.Matched && proposal.Status != ProposalStatus.Withdrawn)
        {
          <div class="flex gap-2 mt-4">
            <a asp-action="Edit" asp-route-id="@proposal.ProposalId" class="btn btn-sm btn-outline border-slate-300 text-slate-700 hover:bg-slate-100">
              <i class="fas fa-edit"></i>Edit
            </a>
            <form asp-action="Withdraw" asp-route-id="@proposal.ProposalId" method="post"
                  onsubmit="return confirm('Are you sure you want to withdraw this proposal?')">
              @Html.AntiForgeryToken()
              <button type="submit" class="btn btn-sm btn-outline border-rose-300 text-rose-600 hover:bg-rose-50">
                <i class="fas fa-times-circle"></i>Withdraw
              </button>
            </form>
          </div>
        }
    </div>
  }
}

